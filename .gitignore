__pycache__/
*.pyc
venv/
.venv/
*.pt
.streamlit/
yolov8n.pt
.pytest_cache/

# Everything in output/ is regenerated by running the pipeline -- no
# reason to carry annotated_video.mp4 (tens of MB) and friends around in
# git history. Keep the folder itself (and a couple of tiny CSVs/JSON as
# a worked example) via the .gitkeep + explicit !exceptions below.
output/*
!output/.gitkeep
!output/analytics_raw.csv
!output/analytics_hourly.csv
!output/summary.json
ARCHITECTURE_AND_CODE_GUIDE.md
